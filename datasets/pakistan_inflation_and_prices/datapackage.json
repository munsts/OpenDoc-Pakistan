{
  "name": "pakistan-inflation-and-prices",
  "title": "Pakistan Inflation and SPI Prices",
  "description": "Official Pakistan Bureau of Statistics inflation and price data: CPI/WPI historical indices, inflation rates, weekly SPI city-item prices, weekly SPI summaries and item changes, and monthly SPI city-item average prices.",
  "version": "0.1.0",
  "keywords": ["finance", "inflation", "cpi", "spi", "wpi", "prices", "pakistan", "pbs"],
  "homepage": "https://www.pbs.gov.pk/price-statistics/",
  "licenses": [
    {
      "name": "LicenseRef-PBS-Public-Website",
      "path": "https://www.pbs.gov.pk/price-statistics/",
      "title": "Pakistan Bureau of Statistics public website data - redistribution license not explicitly stated"
    }
  ],
  "resources": [
