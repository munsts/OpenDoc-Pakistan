      "path": "data/processed/price_indices_historical.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "schema": {
        "fields": [
          {"name": "period", "type": "string"},
          {"name": "year", "type": "integer"},
          {"name": "month", "type": "integer"},
