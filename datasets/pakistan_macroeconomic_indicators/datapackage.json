{
  "name": "pakistan-macroeconomic-indicators",
  "title": "Pakistan Macroeconomic Indicators (2010-2025)",
  "description": "Annual macroeconomic indicators for Pakistan from the year 2010 to 2025.",
  "version": "1.0.0",
  "keywords": ["economics", "gdp", "inflation", "trade", "remittances", "pakistan"],
  "homepage": "https://github.com/pakistan-data-commons/pakistan-macroeconomic-indicators",
  "licenses": [
    {
      "name": "PDDL-1.0",
      "path": "https://opendatacommons.org/licenses/pddl/1-0/",
      "title": "Open Data Commons Public Domain Dedication and License"
    }
  ],
  "resources": [
    {
      "name": "macroeconomic_indicators",
      "path": "data/processed/macroeconomic_indicators.csv",
      "profile": "tabular-data-resource",
      "schema": {
        "fields": [
          {"name": "year", "type": "integer"},
          {"name": "gdp_growth_pct", "type": "number"},
          {"name": "cpi_inflation_pct", "type": "number"},
          {"name": "exports_billion_usd", "type": "number"},
          {"name": "imports_billion_usd", "type": "number"},
          {"name": "remittances_billion_usd", "type": "number"},
          {"name": "unemployment_rate_pct", "type": "number"}
        ]
      }
    }
  ]
}
